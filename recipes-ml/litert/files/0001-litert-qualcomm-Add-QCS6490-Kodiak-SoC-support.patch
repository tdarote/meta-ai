From 70ae075f04b3107f18c933745cd894fe1f51b472 Mon Sep 17 00:00:00 2001
From: Tushar Darote <tdarote@qti.qualcomm.com>
Date: Thu, 9 Jul 2026 14:17:40 +0530
Subject: [PATCH 1/7] litert/qualcomm: Add QCS6490 (Kodiak) SoC support

QCS6490 (Kodiak / RB3 Gen2) reports `socModel = 93` from QNN's
`deviceGetPlatformInfo` and shares the V68 HTP architecture with
QCM6490. Add the SoC ID to the `SnapdragonModel` enum and entries to
the SoC table so on-device auto-detection succeeds.

Also expose the names through:
  * the supported-SoC CSV used by docs/tooling,
  * the Python AOT target enum, and
  * the parameterized compiler-plugin test (`kSupportedSocModels`).

QCM6490 (soc_model id 35) was already used in the table but missing
from the enum and the Python target list; add it for consistency so
host-side AOT compilation via `--soc_model QCM6490`/`QCS6490` works
on both x86 and aarch64.

Upstream-Status: Submitted [https://github.com/google-ai-edge/LiteRT/pull/8345]
Signed-off-by: Tushar Darote <tdarote@qti.qualcomm.com>
---
 litert/python/aot/vendors/qualcomm/target.py                | 2 ++
 .../vendors/qualcomm/compiler/qnn_compiler_plugin_test.cc   | 2 ++
 litert/vendors/qualcomm/core/schema/soc_table.cc            | 6 ++++++
 litert/vendors/qualcomm/core/schema/soc_table.h             | 2 ++
 litert/vendors/qualcomm/supported_soc.csv                   | 1 +
 5 files changed, 13 insertions(+)

diff --git a/litert/python/aot/vendors/qualcomm/target.py b/litert/python/aot/vendors/qualcomm/target.py
index 8fb40dc2..60a5618c 100644
--- a/litert/python/aot/vendors/qualcomm/target.py
+++ b/litert/python/aot/vendors/qualcomm/target.py
@@ -27,6 +27,8 @@ class SocModel(StrEnum):
 
   ALL = "ALL"
 
+  QCM6490 = "QCM6490"
+  QCS6490 = "QCS6490"
   SA8255 = "SA8255"
   SA8295 = "SA8295"
   SM8350 = "SM8350"
diff --git a/litert/vendors/qualcomm/compiler/qnn_compiler_plugin_test.cc b/litert/vendors/qualcomm/compiler/qnn_compiler_plugin_test.cc
index 14ae51d6..bfc30d86 100644
--- a/litert/vendors/qualcomm/compiler/qnn_compiler_plugin_test.cc
+++ b/litert/vendors/qualcomm/compiler/qnn_compiler_plugin_test.cc
@@ -170,6 +170,8 @@ const auto kSupportedOps =
                     );
 
 const auto kSupportedSocModels = Values(
+    "QCM6490",
+    "QCS6490",
     "SA8295",
     "SA8255",
     "SM8350",
