@@ -60,6 +63,9 @@ constexpr SocInfo kSocInfos[] = {
     {SocInfo("SM8850", SnapdragonModel::SM8850, DspArch::V81,
              8  // vtcm_size_in_mb
              )},
+    {SocInfo("QCS6490", SnapdragonModel::QCS6490, DspArch::V68,
+             8  // vtcm_size_in_mb
+             )},
     {SocInfo("SAR2230P", SnapdragonModel::SAR2230P, DspArch::V81,
              4  // vtcm_size_in_mb
              )},
